<UserControl x:Class="LemonSubtitleStudio.Views.VideoToAudioView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Background="#111125">
    <Grid Background="#111125">
        <Grid.RowDefinitions>
            <RowDefinition Height="56" />
            <RowDefinition Height="48" />
            <RowDefinition Height="*" />
            <RowDefinition Height="36" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#111125" BorderBrush="#534433" BorderThickness="0,0,0,1" Padding="16,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Video → Audio" FontSize="20" FontWeight="Bold" Foreground="#FFB95C" Margin="0,0,12,0" />
                    <Border Background="#28283D" CornerRadius="12" Padding="12,4" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding Tasks.Count, StringFormat={}{0} files}" Foreground="#E2E0FC" FontSize="11" />
                            <TextBlock Text=" | " Foreground="#534433" FontSize="11" Margin="4,0" />
                            <TextBlock Text="Memory: " Foreground="#D9C3AC" FontSize="11" />
                            <TextBlock Text="{Binding MemoryUsage}" Foreground="#E2E0FC" FontSize="11" Margin="0,0,4,0" />
                            <TextBlock Text="CPU: " Foreground="#D9C3AC" FontSize="11" />
                            <TextBlock Text="{Binding CpuUsage}" Foreground="#E2E0FC" FontSize="11" />
                        </StackPanel>
                    </Border>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="Export All" Style="{StaticResource MaterialDesignOutlinedButton}" Command="{Binding ExportAllCommand}" Margin="0,0,8,0" Padding="12,6" />
                    <Button Content="Start / Extract" Style="{StaticResource MaterialDesignRaisedButton}" Command="{Binding StartProcessingCommand}" Padding="16,6" />
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1" Background="#1A1A2E" BorderBrush="#534433" BorderThickness="0,0,0,1" Padding="16,0">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal" Margin="0,0,20,0">
                    <TextBlock Text="FORMAT" Style="{StaticResource LabelCapsStyle}" Margin="0,0,8,0" VerticalAlignment="Center" />
                    <ComboBox ItemsSource="{Binding OutputFormats}" SelectedItem="{Binding SelectedFormat}" Width="140" Style="{StaticResource MaterialDesignFloatingHintComboBox}" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,20,0">
                    <TextBlock Text="BITRATE" Style="{StaticResource LabelCapsStyle}" Margin="0,0,8,0" VerticalAlignment="Center" />
                    <Slider Minimum="64" Maximum="320" Value="{Binding Bitrate}" Width="120" VerticalAlignment="Center" />
                    <TextBlock Text="{Binding Bitrate, StringFormat={} {0} kbps}" Foreground="#FFB95C" FontSize="11" FontFamily="Consolas" Margin="8,0,0,0" VerticalAlignment="Center" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <TextBlock Text="OUTPUT DIR" Style="{StaticResource LabelCapsStyle}" Margin="0,0,8,0" VerticalAlignment="Center" />
                    <Border Background="#333348" CornerRadius="4" Padding="8,4" BorderBrush="#534433" BorderThickness="1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{Binding OutputDirectory}" Foreground="#D9C3AC" FontSize="11" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                            <Button Grid.Column="1" Background="Transparent" BorderThickness="0" Command="{Binding BrowseOutputDirectoryCommand}" Cursor="Hand" Padding="4,0">
                                <materialDesign:PackIcon Kind="FolderOpen" Width="14" Height="14" Foreground="#FFA500" />
                            </Button>
                        </Grid>
                    </Border>
                </StackPanel>
            </StackPanel>
        </Border>

        <Grid Grid.Row="2" Margin="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="35*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="65*" />
            </Grid.ColumnDefinitions>

            <!-- Left: Extraction Queue -->
            <Border Grid.Column="0" Background="#1E1E32" BorderBrush="#534433" BorderThickness="1" CornerRadius="8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Border Background="#28283D" Padding="12,8" BorderBrush="#534433" BorderThickness="0,0,0,1" CornerRadius="8,8,0,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Extraction Queue" Foreground="#E2E0FC" FontSize="14" FontWeight="Bold" />
                            <Border Grid.Column="1" Background="#294A77" CornerRadius="10" Padding="8,2">
                                <TextBlock Text="{Binding PendingCount, StringFormat={}{0} Pending}" Foreground="#FFB95C" FontSize="10" FontWeight="Bold" />
                            </Border>
                        </Grid>
                    </Border>
                    <ScrollViewer Grid.Row="1" Margin="4,0,4,4" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding Tasks}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="4,2" Padding="8,6" Background="#1E1E32" CornerRadius="0" BorderBrush="#2A2A3E" BorderThickness="0,0,0,1">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <materialDesign:PackIcon Grid.Column="0" Kind="FileVideo" Width="20" Height="20" Foreground="#FFB95C" Margin="0,0,8,0" VerticalAlignment="Center" />
                                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding FileName}" Foreground="#E2E0FC" FontSize="12" FontWeight="Bold" TextTrimming="CharacterEllipsis" />
                                                    <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                                        <TextBlock Text="Size: " Foreground="#606070" FontSize="10" />
                                                        <TextBlock Text="{Binding FileSizeFormatted}" Foreground="#606070" FontSize="10" Margin="0,0,8,0" />
                                                        <TextBlock Text="Dur: " Foreground="#606070" FontSize="10" />
                                                        <TextBlock Text="{Binding DurationFormatted}" Foreground="#606070" FontSize="10" />
                                                    </StackPanel>
                                                </StackPanel>
                                                <TextBlock Grid.Column="2" Text="{Binding Progress, StringFormat={}{0}%}" Foreground="#FFB95C" FontSize="11" FontFamily="Consolas" VerticalAlignment="Center" />
                                            </Grid>
                                            <ProgressBar Grid.Row="1" Value="{Binding Progress}" Maximum="100" Height="2" Margin="0,4,0,2" Background="#333348" Foreground="#FFA500" BorderThickness="0" />
                                            <Grid Grid.Row="2">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="{Binding Status}" Foreground="#606070" FontSize="10" FontFamily="Consolas" />
                                                <TextBlock Grid.Column="1" Text="{Binding RemainingTimeFormatted, StringFormat={}Remaining: {0}}" Foreground="#606070" FontSize="10" FontFamily="Consolas" />
                                            </Grid>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>

            <GridSplitter Grid.Column="1" Width="4" Background="Transparent" />

            <!-- Right: Waveform + Controls -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="140" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="#1E1E32" BorderBrush="#534433" BorderThickness="1" CornerRadius="8" Margin="0,0,0,6">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="24">
                            <Border Height="120" CornerRadius="8" Margin="0,0,0,24" Padding="12" Background="#1A1A2E">
                                <ItemsControl ItemsSource="{Binding WaveformData}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <VirtualizingStackPanel Orientation="Horizontal" IsItemsHost="True" VerticalAlignment="Bottom" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Width="4" Background="#FFA500" CornerRadius="2" Opacity="0.6" VerticalAlignment="Bottom" Height="{Binding}" Margin="1,0" />
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Border>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <Button Content="⏮" Background="Transparent" BorderThickness="0" Foreground="#D9C3AC" FontSize="20" Width="40" Height="40" Margin="4" />
                                <Border Width="56" Height="56" CornerRadius="28" Background="#FFA500" Margin="12,0">
                                    <Button Content="▶" Background="Transparent" BorderThickness="0" Foreground="#462A00" FontSize="24" Command="{Binding PlayCommand}" />
                                </Border>
                                <Button Content="⏭" Background="Transparent" BorderThickness="0" Foreground="#D9C3AC" FontSize="20" Width="40" Height="40" Margin="4" />
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Extraction Log -->
                <Border Grid.Row="1" Background="#1E1E32" BorderBrush="#534433" BorderThickness="1" CornerRadius="8" Margin="0,6,0,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <Border Background="#28283D" Padding="12,4" BorderBrush="#534433" BorderThickness="0,0,0,1" CornerRadius="8,8,0,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="EXTRACTION LOG" Foreground="#D9C3AC" FontSize="10" FontWeight="Bold" />
                                <StackPanel Grid.Column="1" Orientation="Horizontal">
                                    <TextBlock Text="0 ERRORS" Foreground="#FFB95C" FontSize="10" FontFamily="Consolas" Margin="0,0,8,0" />
                                    <TextBlock Text="2 WARNINGS" Foreground="#98DDFF" FontSize="10" FontFamily="Consolas" />
                                </StackPanel>
                            </Grid>
                        </Border>
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="8">
                            <ItemsControl ItemsSource="{Binding Logs}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}" Foreground="#D9C3AC" FontSize="11" FontFamily="Consolas" Padding="1" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <Border Grid.Row="3" Background="#1A1A2E" BorderBrush="#534433" BorderThickness="0,1,0,0" Padding="12,0">
            <Grid>
                <Button Content="Clear Queue" Style="{StaticResource MaterialDesignOutlinedButton}" Command="{Binding ClearQueueCommand}" HorizontalAlignment="Left" VerticalAlignment="Center" />
            </Grid>
        </Border>
    </Grid>
</UserControl>
