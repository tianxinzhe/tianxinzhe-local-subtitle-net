<UserControl x:Class="LemonSubtitleStudio.Views.SubtitleEditorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Background="#0F1419">
    <Grid Background="#0F1419">
        <Grid.RowDefinitions>
            <RowDefinition Height="72" />
            <RowDefinition Height="280" />
            <RowDefinition Height="*" />
            <RowDefinition Height="40" />
        </Grid.RowDefinitions>
        <materialDesign:Card Grid.Row="0" Margin="8" Padding="16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                    <materialDesign:PackIcon Kind="Edit" Width="24" Height="24" Foreground="#FFA500" Margin="0,0,8,0" />
                    <TextBlock Text="字幕编辑" FontSize="18" FontWeight="Bold" Foreground="White" Margin="0,0,16,0" />
                    <TextBlock Text="当前文件: " Foreground="#A0A0B0" />
                    <TextBlock Text="{Binding CurrentFileName}" Foreground="#FFA500" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Button Content="打开视频/音频" Style="{StaticResource SecondaryButtonStyle}" Command="{Binding OpenMediaCommand}" Margin="0,0,8,0" />
                    <Button Content="打开字幕" Style="{StaticResource SecondaryButtonStyle}" Command="{Binding OpenSubtitleCommand}" Margin="0,0,8,0" />
                    <Button Content="保存" Style="{StaticResource PrimaryButtonStyle}" Command="{Binding SaveCommand}" />
                </StackPanel>
            </Grid>
        </materialDesign:Card>
        <materialDesign:Card Grid.Row="1" Margin="8" Padding="8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="200" />
                </Grid.ColumnDefinitions>
                <materialDesign:Card Grid.Column="0" Padding="4" Margin="4" Background="#0F0F1A">
                    <MediaElement x:Name="MediaPlayer" Stretch="Uniform" LoadedBehavior="Manual" />
                </materialDesign:Card>
                <StackPanel Grid.Column="1" Margin="4">
                    <Button Content="播放" Width="100" Style="{StaticResource PrimaryButtonStyle}" Margin="4" Command="{Binding PlayCommand}" />
                    <Button Content="暂停" Width="100" Style="{StaticResource SecondaryButtonStyle}" Margin="4" Command="{Binding PauseCommand}" />
                    <Button Content="停止" Width="100" Style="{StaticResource SecondaryButtonStyle}" Margin="4" Command="{Binding StopCommand}" />
                    <Slider Minimum="0" Maximum="100" Value="{Binding PlaybackProgress}" Margin="4" />
                    <TextBlock Foreground="#A0A0B0" Margin="4">
                        <Run Text="{Binding CurrentTime}" />
                        <Run Text=" / " />
                        <Run Text="{Binding TotalTime}" />
                    </TextBlock>
                </StackPanel>
            </Grid>
        </materialDesign:Card>
        <Grid Grid.Row="2" Margin="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="300" />
            </Grid.ColumnDefinitions>
            <materialDesign:Card Grid.Column="0" Padding="8" Margin="4">
                <DataGrid ItemsSource="{Binding Subtitles}" AutoGenerateColumns="False" 
                          SelectedItem="{Binding SelectedSubtitle}" Style="{StaticResource DataGridStyle}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="序号" Binding="{Binding Index}" Width="60" />
                        <DataGridTextColumn Header="开始时间" Binding="{Binding StartTimeFormatted}" Width="120" />
                        <DataGridTextColumn Header="结束时间" Binding="{Binding EndTimeFormatted}" Width="120" />
                        <DataGridTextColumn Header="字幕内容" Binding="{Binding OriginalText}" Width="*" />
                    </DataGrid.Columns>
                </DataGrid>
            </materialDesign:Card>
            <materialDesign:Card Grid.Column="1" Padding="8" Margin="4">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <materialDesign:PackIcon Kind="Edit" Width="16" Height="16" Foreground="#FFA500" Margin="0,0,4,0" />
                        <TextBlock Text="编辑字幕" Foreground="#FFA500" />
                    </StackPanel>
                    <TextBox Text="{Binding SelectedSubtitle.OriginalText, Mode=TwoWay}" 
                             AcceptsReturn="True" Height="100" Margin="0,0,0,8" Style="{StaticResource TextBoxStyle}" />
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <Button Content="添加" Style="{StaticResource PrimaryButtonStyle}" Command="{Binding AddSubtitleCommand}" />
                        <Button Content="删除" Style="{StaticResource SecondaryButtonStyle}" Command="{Binding DeleteSubtitleCommand}" Margin="8,0,0,0" />
                    </StackPanel>
                    <StackPanel>
                        <TextBlock Text="开始时间" Foreground="#A0A0B0" FontSize="12" Margin="0,0,0,4" />
                        <TextBox Text="{Binding EditStartTime}" Width="150" Margin="0,0,0,8" Style="{StaticResource TextBoxStyle}" />
                        <TextBlock Text="结束时间" Foreground="#A0A0B0" FontSize="12" Margin="0,0,0,4" />
                        <TextBox Text="{Binding EditEndTime}" Width="150" Style="{StaticResource TextBoxStyle}" />
                    </StackPanel>
                </StackPanel>
            </materialDesign:Card>
        </Grid>
        <materialDesign:Card Grid.Row="3" Margin="8" Padding="8">
            <TextBlock Text="{Binding StatusMessage}" Foreground="#A0A0B0" />
        </materialDesign:Card>
    </Grid>
</UserControl>