<UserControl x:Class="LemonSubtitleStudio.Views.SubtitleEditorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Background="#111125">
    <Grid Background="#111125">
        <Grid.RowDefinitions>
            <RowDefinition Height="56" />
            <RowDefinition Height="*" />
            <RowDefinition Height="96" />
            <RowDefinition Height="280" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#111125" BorderBrush="#534433" BorderThickness="0,0,0,1" Padding="16,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="Import Media" Style="{StaticResource MaterialDesignOutlinedButton}" Command="{Binding OpenMediaCommand}" Margin="0,0,8,0" Padding="12,6" />
                    <Button Content="Import Subtitle" Style="{StaticResource MaterialDesignOutlinedButton}" Command="{Binding OpenSubtitleCommand}" Padding="12,6" />
                    <TextBlock Text="{Binding CurrentFileName}" Foreground="#D9C3AC" FontSize="12" Margin="16,0,0,0" VerticalAlignment="Center" />
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="Export All" Style="{StaticResource MaterialDesignOutlinedButton}" Command="{Binding ExportAllCommand}" Margin="0,0,8,0" Padding="12,6" />
                    <Button Content="Save" Style="{StaticResource MaterialDesignRaisedButton}" Command="{Binding SaveCommand}" Padding="16,6" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Top: Preview + Segments -->
        <Grid Grid.Row="1" Margin="12,12,12,6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="320" />
            </Grid.ColumnDefinitions>

            <!-- Video Player -->
            <Border Grid.Column="0" Background="#1E1E32" BorderBrush="#534433" BorderThickness="1" CornerRadius="8">
                <Grid>
                    <MediaElement x:Name="MediaPlayer" Stretch="Uniform" LoadedBehavior="Manual" />
                    <Border VerticalAlignment="Bottom" Background="#1A1A2E" Padding="12,6" BorderBrush="#534433" BorderThickness="0,1,0,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Orientation="Horizontal">
                                <Button Content="▶" Background="Transparent" BorderThickness="0" Foreground="#FFA500" FontSize="16" Command="{Binding PlayCommand}" Width="28" Height="28" />
                                <Button Content="⏸" Background="Transparent" BorderThickness="0" Foreground="#D9C3AC" FontSize="16" Command="{Binding PauseCommand}" Width="28" Height="28" />
                                <Button Content="⏹" Background="Transparent" BorderThickness="0" Foreground="#D9C3AC" FontSize="16" Command="{Binding StopCommand}" Width="28" Height="28" />
                            </StackPanel>
                            <Slider Grid.Column="1" Minimum="0" Maximum="100" Value="{Binding PlaybackProgress}" Margin="12,0" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="2" Foreground="#D9C3AC" FontSize="11" VerticalAlignment="Center">
                                <Run Text="{Binding CurrentTime}" /><Run Text=" / " /><Run Text="{Binding TotalTime}" />
                            </TextBlock>
                        </Grid>
                    </Border>
                </Grid>
            </Border>

            <GridSplitter Grid.Column="1" Width="4" Background="Transparent" />

            <!-- Segments Panel -->
            <Border Grid.Column="2" Background="#1E1E32" BorderBrush="#534433" BorderThickness="1" CornerRadius="8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Border Background="#28283D" Padding="12,6" BorderBrush="#534433" BorderThickness="0,0,0,1" CornerRadius="8,8,0,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Segments" Foreground="#FFB95C" FontSize="14" FontWeight="Bold" />
                            <TextBlock Grid.Column="1" Text="{Binding Subtitles.Count, StringFormat={}{0} total}" Foreground="#D9C3AC" FontSize="11" VerticalAlignment="Center" />
                        </Grid>
                    </Border>
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding Subtitles}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="8,6" BorderBrush="#2A2A3E" BorderThickness="0,0,0,1" Background="#111125">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>
                                            <TextBlock Text="{Binding Index, StringFormat={}#{0}}" Foreground="#FFB95C" FontSize="11" FontWeight="Bold" Margin="0,0,8,0" />
                                            <TextBlock Grid.Column="1" Text="{Binding StartTimeFormatted}" Foreground="#D9C3AC" FontSize="10" FontFamily="Consolas" />
                                            <TextBlock Grid.Column="2" Text="{Binding EndTimeFormatted}" Foreground="#D9C3AC" FontSize="10" FontFamily="Consolas" HorizontalAlignment="Right" />
                                            <TextBlock Grid.Row="1" Grid.ColumnSpan="3" Text="{Binding OriginalText}" Foreground="#D9C3AC" FontSize="11" TextTrimming="CharacterEllipsis" Margin="0,2,0,0" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>

        <!-- Timeline -->
        <Border Grid.Row="2" Background="#28283D" BorderBrush="#534433" BorderThickness="1,0,1,0" Margin="12,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="24" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Border Grid.Row="0" BorderBrush="#534433" BorderThickness="0,0,0,1" Padding="8,0">
                    <ItemsControl ItemsSource="{Binding TimelineMarkers}" Margin="0">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}" Foreground="#D9C3AC" FontSize="10" FontFamily="Consolas" Margin="0,0,28,0" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Border>
                <ItemsControl Grid.Row="1" ItemsSource="{Binding Subtitles}" Margin="8,4">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <Canvas Background="Transparent" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Width="{Binding TimelineWidth}" Height="32" Background="#1E1E32" CornerRadius="4" BorderBrush="#534433" BorderThickness="1" Canvas.Left="{Binding TimelineOffset}" Canvas.Top="4">
                                <TextBlock Text="{Binding OriginalText}" Foreground="#D9C3AC" FontSize="10" TextTrimming="CharacterEllipsis" Margin="4,0" VerticalAlignment="Center" />
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Grid>
        </Border>

        <!-- Bottom: Split Editor -->
        <Grid Grid.Row="3" Margin="12,6,12,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="4" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Original Text -->
            <Border Grid.Column="0" Background="#1E1E32" BorderBrush="#534433" BorderThickness="1" CornerRadius="8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Border Background="#28283D" Padding="12,6" BorderBrush="#534433" BorderThickness="0,0,0,1" CornerRadius="8,8,0,0">
                        <TextBlock Text="ORIGINAL" Foreground="#D9C3AC" FontSize="10" FontWeight="Bold" />
                    </Border>
                    <TextBox Grid.Row="1" Text="{Binding SelectedSubtitle.OriginalText, Mode=TwoWay}"
                             Background="Transparent" Foreground="#E2E0FC" BorderThickness="0"
                             AcceptsReturn="True" FontSize="14" Padding="12" />
                </Grid>
            </Border>

            <GridSplitter Grid.Column="1" Width="4" Background="Transparent" />

            <!-- Translation + Metadata -->
            <Border Grid.Column="2" Background="#1E1E32" BorderBrush="#534433" BorderThickness="1" CornerRadius="8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Border Background="#28283D" Padding="12,6" BorderBrush="#534433" BorderThickness="0,0,0,1" CornerRadius="8,8,0,0">
                        <TextBlock Text="TRANSLATION" Foreground="#FFA500" FontSize="10" FontWeight="Bold" />
                    </Border>
                    <Grid Grid.Row="1" Margin="12,8,12,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Start:" Foreground="#D9C3AC" FontSize="11" VerticalAlignment="Center" />
                        <TextBox Grid.Column="1" Text="{Binding EditStartTime}" Width="80" Style="{StaticResource MaterialDesignFloatingHintTextBox}" Margin="4,0,8,0" />
                        <TextBlock Grid.Column="2" Text="End:" Foreground="#D9C3AC" FontSize="11" VerticalAlignment="Center" />
                        <TextBox Grid.Column="3" Text="{Binding EditEndTime}" Width="80" Style="{StaticResource MaterialDesignFloatingHintTextBox}" Margin="4,0,8,0" />
                        <TextBlock Grid.Column="4" Text="Duration:" Foreground="#D9C3AC" FontSize="11" VerticalAlignment="Center" />
                        <TextBlock Grid.Column="5" Text="{Binding DurationFormatted}" Foreground="#FFB95C" FontSize="11" FontFamily="Consolas" VerticalAlignment="Center" Margin="0,0,12,0" />
                        <TextBlock Grid.Column="6" Text="CPS:" Foreground="#D9C3AC" FontSize="11" VerticalAlignment="Center" HorizontalAlignment="Right" />
                        <TextBlock Grid.Column="7" Text="{Binding CpsFormatted}" Foreground="#FFB95C" FontSize="11" FontFamily="Consolas" VerticalAlignment="Center" Margin="4,0,0,0" />
                    </Grid>
                    <TextBox Grid.Row="2" Text="{Binding SelectedSubtitle.TranslatedText, Mode=TwoWay}"
                             Background="#1A1A2E" Foreground="#FFB95C" BorderThickness="0"
                             AcceptsReturn="True" FontSize="14" Padding="12" Margin="0,0,0,8" />
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
