
<UserControl x:Class="LemonSubtitleStudio.Views.SubtitleEditorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:viewModels="clr-namespace:LemonSubtitleStudio.ViewModels">
    <UserControl.DataContext>
        <viewModels:SubtitleEditorViewModel />
    </UserControl.DataContext>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60" />
            <RowDefinition Height="300" />
            <RowDefinition Height="*" />
            <RowDefinition Height="40" />
        </Grid.RowDefinitions>
        <Grid Grid.Row="0" Background="#1A1A2E" Margin="8">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                <TextBlock Text="字幕编辑" FontSize="18" FontWeight="Bold" Foreground="White" Margin="0,0,16,0" />
                <TextBlock Text="当前文件: " Foreground="#A0A0B0" />
                <TextBlock Text="{Binding CurrentFileName}" Foreground="#FFA500" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                <Button Content="打开视频/音频" Style="{StaticResource SecondaryButtonStyle}" Command="{Binding OpenMediaCommand}" Margin="0,0,8,0" />
                <Button Content="打开字幕" Style="{StaticResource SecondaryButtonStyle}" Command="{Binding OpenSubtitleCommand}" Margin="0,0,8,0" />
                <Button Content="保存" Style="{StaticResource PrimaryButtonStyle}" Command="{Binding SaveCommand}" />
            </StackPanel>
        </Grid>
        <Grid Grid.Row="1" Background="#16213E" Margin="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="200" />
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0" Background="#0F0F1A" CornerRadius="8" Margin="4">
                <MediaElement x:Name="MediaPlayer" Stretch="Uniform" LoadedBehavior="Manual" />
            </Border>
            <StackPanel Grid.Column="1" Margin="4">
                <Button Content="播放" Width="100" Style="{StaticResource PrimaryButtonStyle}" Margin="4" />
                <Button Content="暂停" Width="100" Style="{StaticResource SecondaryButtonStyle}" Margin="4" />
                <Button Content="停止" Width="100" Style="{StaticResource SecondaryButtonStyle}" Margin="4" />
                <Slider Minimum="0" Maximum="100" Value="{Binding PlaybackProgress}" Margin="4" />
                <TextBlock Text="{Binding CurrentTime} / {Binding TotalTime}" Foreground="#A0A0B0" Margin="4" />
            </StackPanel>
        </Grid>
        <Grid Grid.Row="2" Margin="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="300" />
            </Grid.ColumnDefinitions>
            <DataGrid Grid.Column="0" ItemsSource="{Binding Subtitles}" AutoGenerateColumns="False" 
                      SelectedItem="{Binding SelectedSubtitle}" Style="{StaticResource DataGridStyle}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="序号" Binding="{Binding Index}" Width="60" />
                    <DataGridTextColumn Header="开始时间" Binding="{Binding StartTimeFormatted}" Width="120" />
                    <DataGridTextColumn Header="结束时间" Binding="{Binding EndTimeFormatted}" Width="120" />
                    <DataGridTextColumn Header="字幕内容" Binding="{Binding OriginalText}" Width="*" />
                </DataGrid.Columns>
            </DataGrid>
            <Border Grid.Column="1" Background="#1A1A2E" CornerRadius="8" Margin="4">
                <StackPanel>
                    <TextBlock Text="编辑字幕" Foreground="#FFA500" Margin="8" />
                    <TextBox Text="{Binding SelectedSubtitle.OriginalText, Mode=TwoWay}" 
                             AcceptsReturn="True" Height="100" Margin="8" Style="{StaticResource TextBoxStyle}" />
                    <StackPanel Orientation="Horizontal" Margin="8">
                        <Button Content="添加" Style="{StaticResource PrimaryButtonStyle}" Command="{Binding AddSubtitleCommand}" />
                        <Button Content="删除" Style="{StaticResource SecondaryButtonStyle}" Command="{Binding DeleteSubtitleCommand}" Margin="8,0,0,0" />
                    </StackPanel>
                    <StackPanel Margin="8">
                        <TextBlock Text="开始时间" Foreground="#A0A0B0" FontSize="12" />
                        <TextBox Text="{Binding EditStartTime}" Width="150" Margin="4" Style="{StaticResource TextBoxStyle}" />
                        <TextBlock Text="结束时间" Foreground="#A0A0B0" FontSize="12" />
                        <TextBox Text="{Binding EditEndTime}" Width="150" Margin="4" Style="{StaticResource TextBoxStyle}" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
        <Grid Grid.Row="3" Background="#16213E" Margin="8">
            <TextBlock Text="{Binding StatusMessage}" Foreground="#A0A0B0" />
        </Grid>
    </Grid>
</UserControl>
