<UserControl x:Class="LemonSubtitleStudio.Views.SubtitleTranslationView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Background="#0F1419">
    <Grid Background="#0F1419">
        <Grid.RowDefinitions>
            <RowDefinition Height="72" />
            <RowDefinition Height="50" />
            <RowDefinition Height="*" />
            <RowDefinition Height="40" />
        </Grid.RowDefinitions>
        <materialDesign:Card Grid.Row="0" Margin="8" Padding="16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                    <materialDesign:PackIcon Kind="Translate" Width="24" Height="24" Foreground="#FFA500" Margin="0,0,8,0" />
                    <TextBlock Text="字幕翻译" FontSize="18" FontWeight="Bold" Foreground="White" Margin="0,0,16,0" />
                    <Border Background="#FFA500" CornerRadius="10" Padding="4,1" MinWidth="20">
                        <TextBlock Text="{Binding Tasks.Count}" Foreground="White" FontSize="12" FontWeight="Bold" />
                    </Border>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Button Content="导出全部" Style="{StaticResource SecondaryButtonStyle}" Command="{Binding ExportAllCommand}" Margin="0,0,8,0" />
                    <Button Content="开始翻译" Style="{StaticResource PrimaryButtonStyle}" Command="{Binding StartProcessingCommand}" />
                </StackPanel>
            </Grid>
        </materialDesign:Card>
        <materialDesign:Card Grid.Row="1" Margin="8" Padding="16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                    <ComboBox ItemsSource="{Binding Languages}" SelectedItem="{Binding SourceLanguage}" Width="100" Style="{StaticResource ComboBoxStyle}" Margin="0,0,8,0" />
                    <materialDesign:PackIcon Kind="ArrowRight" Width="20" Height="20" Foreground="#FFA500" Margin="0,0,8,0" />
                    <ComboBox ItemsSource="{Binding Languages}" SelectedItem="{Binding TargetLanguage}" Width="100" Style="{StaticResource ComboBoxStyle}" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <TextBlock Text="输出目录:" Foreground="#A0A0B0" Margin="0,0,8,0" />
                    <TextBox Text="{Binding OutputDirectory}" Width="200" Style="{StaticResource TextBoxStyle}" Margin="0,0,8,0" />
                    <Button Content="浏览" Style="{StaticResource SecondaryButtonStyle}" Command="{Binding BrowseOutputDirectoryCommand}" />
                </StackPanel>
            </Grid>
        </materialDesign:Card>
        <Grid Grid.Row="2" Margin="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320" MinWidth="200" MaxWidth="400" />
                <ColumnDefinition Width="4" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <materialDesign:Card Grid.Column="0" Padding="8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="100" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <materialDesign:Card Grid.Row="0" Padding="16" Background="#0F3460" AllowDrop="True" Drop="DropHandler" Cursor="Hand">
                        <materialDesign:Card.InputBindings>
                            <MouseBinding MouseAction="LeftClick" Command="{Binding SelectFileCommand}" />
                        </materialDesign:Card.InputBindings>
                        <StackPanel Orientation="Vertical" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <materialDesign:PackIcon Kind="FolderOpen" Width="40" Height="40" Foreground="#FFA500" Margin="0,0,0,8" />
                            <TextBlock Text="拖拽字幕文件到这里" Foreground="#A0A0B0" />
                            <TextBlock Text="或点击选择" Foreground="#505060" FontSize="12" />
                        </StackPanel>
                    </materialDesign:Card>
                    <ListBox Grid.Row="1" ItemsSource="{Binding Tasks}" Margin="8" Background="Transparent">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <materialDesign:Card Padding="8" Margin="4">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="FileText" Width="20" Height="20" Foreground="#FFA500" Margin="0,0,8,0" />
                                        <TextBlock Text="{Binding FileName}" Foreground="White" Width="180" TextTrimming="CharacterEllipsis" />
                                        <ProgressBar Value="{Binding Progress}" Width="60" Height="16" Margin="8,0,8,0" Style="{StaticResource ProgressBarStyle}" />
                                        <Border CornerRadius="10" Padding="4,1" MinWidth="40" Background="{Binding Status, Converter={StaticResource StatusColorConverter}}">
                                            <TextBlock Text="{Binding Status, Converter={StaticResource TaskStatusConverter}}" Foreground="White" FontSize="12" />
                                        </Border>
                                    </StackPanel>
                                </materialDesign:Card>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </materialDesign:Card>
            <GridSplitter Grid.Column="1" Width="4" Background="#2A2A4A" ResizeDirection="Columns" />
            <materialDesign:Card Grid.Column="2" Padding="8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <materialDesign:Card Grid.Column="0" Padding="8" Margin="4">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <materialDesign:PackIcon Kind="FileText" Width="16" Height="16" Foreground="#FFA500" Margin="0,0,4,0" />
                                <TextBlock Text="源字幕" Foreground="#FFA500" />
                            </StackPanel>
                            <DataGrid ItemsSource="{Binding Subtitles}" AutoGenerateColumns="False" Style="{StaticResource DataGridStyle}">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="时间" Binding="{Binding StartTimeFormatted}" />
                                    <DataGridTextColumn Header="原文" Binding="{Binding OriginalText}" Width="*" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </StackPanel>
                    </materialDesign:Card>
                    <materialDesign:Card Grid.Column="1" Padding="8" Margin="4">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <materialDesign:PackIcon Kind="Globe" Width="16" Height="16" Foreground="#FFA500" Margin="0,0,4,0" />
                                <TextBlock Text="目标字幕" Foreground="#FFA500" />
                            </StackPanel>
                            <DataGrid ItemsSource="{Binding Subtitles}" AutoGenerateColumns="False" Style="{StaticResource DataGridStyle}">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="时间" Binding="{Binding StartTimeFormatted}" />
                                    <DataGridTextColumn Header="译文" Binding="{Binding TranslatedText}" Width="*" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </StackPanel>
                    </materialDesign:Card>
                </Grid>
            </materialDesign:Card>
        </Grid>
        <materialDesign:Card Grid.Row="3" Margin="8" Padding="8">
            <Button Content="清空队列" Style="{StaticResource SecondaryButtonStyle}" Command="{Binding ClearQueueCommand}" />
        </materialDesign:Card>
    </Grid>
</UserControl>