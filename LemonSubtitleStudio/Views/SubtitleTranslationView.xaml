
<UserControl x:Class="LemonSubtitleStudio.Views.SubtitleTranslationView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:viewModels="clr-namespace:LemonSubtitleStudio.ViewModels">
    <UserControl.DataContext>
        <viewModels:SubtitleTranslationViewModel />
    </UserControl.DataContext>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60" />
            <RowDefinition Height="50" />
            <RowDefinition Height="*" />
            <RowDefinition Height="40" />
        </Grid.RowDefinitions>
        <Grid Grid.Row="0" Background="#1A1A2E" Margin="8">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                <TextBlock Text="字幕翻译" FontSize="18" FontWeight="Bold" Foreground="White" Margin="0,0,16,0" />
                <TextBlock Text="[" Foreground="#FFA500" />
                <TextBlock Text="{Binding Tasks.Count}" Foreground="#FFA500" />
                <TextBlock Text="个文件]" Foreground="#FFA500" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                <Button Content="导出全部" Style="{StaticResource PrimaryButtonStyle}" Command="{Binding ExportAllCommand}" Margin="0,0,8,0" />
                <Button Content="开始翻译" Style="{StaticResource PrimaryButtonStyle}" Command="{Binding StartProcessingCommand}" />
            </StackPanel>
        </Grid>
        <Grid Grid.Row="1" Background="#16213E" Margin="8">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                <ComboBox ItemsSource="{Binding Languages}" SelectedItem="{Binding SourceLanguage}" Width="100" Style="{StaticResource ComboBoxStyle}" Margin="0,0,8,0" />
                <TextBlock Text="→" Foreground="#FFA500" Margin="0,0,8,0" />
                <ComboBox ItemsSource="{Binding Languages}" SelectedItem="{Binding TargetLanguage}" Width="100" Style="{StaticResource ComboBoxStyle}" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                <TextBlock Text="输出目录:" Foreground="#A0A0B0" Margin="0,0,8,0" />
                <TextBox Text="{Binding OutputDirectory}" Width="200" Style="{StaticResource TextBoxStyle}" Margin="0,0,8,0" />
                <Button Content="浏览" Style="{StaticResource SecondaryButtonStyle}" Command="{Binding BrowseOutputDirectoryCommand}" />
            </StackPanel>
        </Grid>
        <Grid Grid.Row="2" Margin="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320" MinWidth="200" MaxWidth="400" />
                <ColumnDefinition Width="4" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid Grid.Column="0" Background="#16213E">
                <Grid.RowDefinitions>
                    <RowDefinition Height="100" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Border Grid.Row="0" BorderBrush="#2A2A4A" BorderThickness="2" CornerRadius="8" Margin="8" 
                        Background="#0F3460" AllowDrop="True" Drop="DropHandler">
                    <StackPanel Orientation="Vertical" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="🌐" FontSize="24" Margin="0,0,0,8" />
                        <TextBlock Text="拖拽字幕文件到这里" Foreground="#A0A0B0" />
                    </StackPanel>
                </Border>
                <ListBox Grid.Row="1" ItemsSource="{Binding Tasks}" Margin="8" Background="Transparent">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Background="#1A1A2E" CornerRadius="4" Margin="2" Padding="8">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding FileName}" Foreground="White" Width="200" TextTrimming="CharacterEllipsis" />
                                    <ProgressBar Value="{Binding Progress}" Width="60" Height="12" Margin="8,0,8,0" Style="{StaticResource ProgressBarStyle}" />
                                    <TextBlock Text="{Binding Status, Converter={StaticResource TaskStatusConverter}}" 
                                               Foreground="{Binding Status, Converter={StaticResource StatusColorConverter}}" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
            <GridSplitter Grid.Column="1" Width="4" Background="#2A2A4A" />
            <Grid Grid.Column="2">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Background="#1A1A2E" Margin="4" CornerRadius="8">
                        <StackPanel>
                            <TextBlock Text="源字幕" Foreground="#FFA500" Margin="8" />
                            <DataGrid ItemsSource="{Binding Subtitles}" AutoGenerateColumns="False" Style="{StaticResource DataGridStyle}">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="时间" Binding="{Binding StartTimeFormatted}" />
                                    <DataGridTextColumn Header="原文" Binding="{Binding OriginalText}" Width="*" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="1" Background="#1A1A2E" Margin="4" CornerRadius="8">
                        <StackPanel>
                            <TextBlock Text="目标字幕" Foreground="#FFA500" Margin="8" />
                            <DataGrid ItemsSource="{Binding Subtitles}" AutoGenerateColumns="False" Style="{StaticResource DataGridStyle}">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="时间" Binding="{Binding StartTimeFormatted}" />
                                    <DataGridTextColumn Header="译文" Binding="{Binding TranslatedText}" Width="*" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>
        </Grid>
        <Grid Grid.Row="3" Background="#16213E" Margin="8">
            <Button Content="清空队列" Command="{Binding ClearQueueCommand}" Style="{StaticResource SecondaryButtonStyle}" />
        </Grid>
    </Grid>
</UserControl>
