<UserControl x:Class="LemonSubtitleStudio.Views.AudioToSubtitleView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Background="#111125">
    <Grid Background="#111125">
        <Grid.RowDefinitions>
            <RowDefinition Height="56" />
            <RowDefinition Height="48" />
            <RowDefinition Height="*" />
            <RowDefinition Height="36" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#111125" BorderBrush="#534433" BorderThickness="0,0,0,1" Padding="16,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Audio → Subtitle" FontSize="20" FontWeight="Bold" Foreground="#FFB95C" Margin="0,0,12,0" />
                    <Border Background="#28283D" CornerRadius="12" Padding="8,4" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <Border Width="6" Height="6" CornerRadius="3" Background="#FFA500" VerticalAlignment="Center" Margin="0,0,6,0" />
                            <TextBlock Text="{Binding CurrentTaskInfo}" Foreground="#D9C3AC" FontSize="11" />
                        </StackPanel>
                    </Border>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="Export All" Style="{StaticResource MaterialDesignOutlinedButton}" Command="{Binding ExportAllCommand}" Margin="0,0,8,0" Padding="12,6" />
                    <Button Content="Start Recognition" Style="{StaticResource MaterialDesignRaisedButton}" Command="{Binding StartProcessingCommand}" Padding="16,6" />
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1" Background="#1A1A2E" BorderBrush="#534433" BorderThickness="0,0,0,1" Padding="16,0">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal" Margin="0,0,20,0">
                    <TextBlock Text="LANGUAGE" Style="{StaticResource LabelCapsStyle}" Margin="0,0,8,0" VerticalAlignment="Center" />
                    <ComboBox ItemsSource="{Binding Languages}" SelectedItem="{Binding SelectedLanguage}" Width="120" Style="{StaticResource MaterialDesignFloatingHintComboBox}" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,20,0">
                    <TextBlock Text="PRECISION" Style="{StaticResource LabelCapsStyle}" Margin="0,0,8,0" VerticalAlignment="Center" />
                    <ComboBox ItemsSource="{Binding ProcessingModes}" SelectedItem="{Binding SelectedProcessingMode}" Width="140" Style="{StaticResource MaterialDesignFloatingHintComboBox}" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,20,0">
                    <TextBlock Text="MODEL" Style="{StaticResource LabelCapsStyle}" Margin="0,0,8,0" VerticalAlignment="Center" />
                    <ComboBox ItemsSource="{Binding AvailableModels}" SelectedItem="{Binding SelectedModel}" Width="120" Style="{StaticResource MaterialDesignFloatingHintComboBox}" />
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="OUTPUT" Style="{StaticResource LabelCapsStyle}" Margin="0,0,8,0" VerticalAlignment="Center" />
                    <ComboBox ItemsSource="{Binding OutputFormats}" SelectedItem="{Binding SelectedOutputFormat}" Width="80" Style="{StaticResource MaterialDesignFloatingHintComboBox}" />
                </StackPanel>
            </StackPanel>
        </Border>

        <Grid Grid.Row="2" Margin="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="35*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="65*" />
            </Grid.ColumnDefinitions>

            <!-- Left: Audio Queue -->
            <Border Grid.Column="0" Background="#1E1E32" BorderBrush="#534433" BorderThickness="1" CornerRadius="8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Margin="8" Padding="24,16" Background="#0C0C1F" BorderBrush="#534433" BorderThickness="1"
                            AllowDrop="True" Drop="DropHandler" Cursor="Hand" CornerRadius="8">
                        <Border.InputBindings>
                            <MouseBinding MouseAction="LeftClick" Command="{Binding SelectFileCommand}" />
                        </Border.InputBindings>
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                            <materialDesign:PackIcon Kind="CloudUpload" Width="32" Height="32" Foreground="#D9C3AC" Margin="0,0,0,8" HorizontalAlignment="Center" />
                            <TextBlock Text="Drop audio files here" Foreground="#D9C3AC" FontSize="14" HorizontalAlignment="Center" />
                            <TextBlock Text="MP3, WAV, FLAC, OGG" Foreground="#606070" FontSize="11" HorizontalAlignment="Center" Margin="0,4,0,0" />
                        </StackPanel>
                    </Border>
                    <ScrollViewer Grid.Row="1" Margin="4,0,4,4" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding Tasks}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="4,2" Padding="8,6" Background="#1E1E32" CornerRadius="0" BorderBrush="#2A2A3E" BorderThickness="0,0,0,1">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <Border Grid.Column="0" Width="36" Height="36" Background="#333348" CornerRadius="8" Margin="0,0,8,0">
                                                <materialDesign:PackIcon Kind="FileMusic" Width="18" Height="18" Foreground="#FFB95C" />
                                            </Border>
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding FileName}" Foreground="#E2E0FC" FontSize="12" FontWeight="Bold" TextTrimming="CharacterEllipsis" />
                                                <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                                    <TextBlock Text="{Binding FileSizeFormatted}" Foreground="#606070" FontSize="10" Margin="0,0,8,0" />
                                                    <TextBlock Text="•" Foreground="#606070" FontSize="10" Margin="0,0,8,0" />
                                                    <TextBlock Text="{Binding DurationFormatted}" Foreground="#606070" FontSize="10" />
                                                </StackPanel>
                                            </StackPanel>
                                            <TextBlock Grid.Column="2" Text="{Binding Progress, StringFormat={}{0}%}" Foreground="#FFB95C" FontSize="11" FontFamily="Consolas" VerticalAlignment="Center" />
                                            <ProgressBar Grid.Row="1" Grid.ColumnSpan="3" Value="{Binding Progress}" Maximum="100" Height="2" Margin="0,4,0,0"
                                                         Background="#333348" Foreground="#FFA500" BorderThickness="0" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>

            <GridSplitter Grid.Column="1" Width="4" Background="Transparent" />

            <!-- Right: Recognition Details -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="140" />
                </Grid.RowDefinitions>

                <!-- Recognition Header -->
                <Border Grid.Row="0" Background="#1E1E32" BorderBrush="#534433" BorderThickness="1" CornerRadius="8" Padding="16" Margin="0,0,0,6">
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="CURRENT STATUS" Foreground="#D9C3AC" FontSize="10" FontWeight="Bold" />
                                <TextBlock Text="{Binding CurrentTaskInfo, FallbackValue='Ready'}" Foreground="#FFB95C" FontSize="16" FontWeight="Bold" />
                            </StackPanel>
                            <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                                <TextBlock Text="{Binding RemainingTimeFormatted, StringFormat={}Time Remaining: {0}}" Foreground="#D9C3AC" FontSize="11" />
                                <TextBlock Text="{Binding OverallProgress, StringFormat={}{0}%}" Foreground="#FFB95C" FontSize="20" FontWeight="Bold" FontFamily="Consolas" HorizontalAlignment="Right" />
                            </StackPanel>
                        </Grid>
                        <Border Margin="0,8,0,0" Height="4" Background="#333348" CornerRadius="2">
                            <Border Width="{Binding OverallProgressPercent}" Height="4" Background="#FFA500" CornerRadius="2" HorizontalAlignment="Left" />
                        </Border>
                    </StackPanel>
                </Border>

                <!-- Subtitle List -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,0,0,6">
                    <ItemsControl ItemsSource="{Binding Subtitles}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,0,4" Padding="12,8" Background="#1E1E32" BorderBrush="#534433" BorderThickness="1" CornerRadius="8">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding StartTimeFormatted}" Foreground="#FFB95C" FontSize="11" FontFamily="Consolas" Margin="0,0,12,0" VerticalAlignment="Center" />
                                        <TextBlock Grid.Column="1" Text="{Binding OriginalText}" Foreground="#E2E0FC" FontSize="13" TextWrapping="Wrap" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <GridSplitter Grid.Row="2" Height="4" Background="Transparent" />

                <!-- Processing Log -->
                <Border Grid.Row="3" Background="#1E1E32" BorderBrush="#534433" BorderThickness="1" CornerRadius="8">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <Border Background="#28283D" Padding="12,4" BorderBrush="#534433" BorderThickness="0,0,0,1" CornerRadius="8,8,0,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="Terminal" Width="14" Height="14" Foreground="#D9C3AC" Margin="0,0,6,0" VerticalAlignment="Center" />
                                    <TextBlock Text="Processing Log" Foreground="#D9C3AC" FontSize="10" FontWeight="Bold" />
                                </StackPanel>
                                <TextBlock Grid.Column="1" Text="{Binding Logs.Count, StringFormat='{}{0} entries'}" Foreground="#606070" FontSize="10" FontFamily="Consolas" VerticalAlignment="Center" />
                            </Grid>
                        </Border>
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="8">
                            <ItemsControl ItemsSource="{Binding Logs}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}" Foreground="#D9C3AC" FontSize="10" FontFamily="Consolas" Padding="1" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <Border Grid.Row="3" Background="#1A1A2E" BorderBrush="#534433" BorderThickness="0,1,0,0" Padding="12,0">
            <Grid>
                <Button Content="Clear Queue" Style="{StaticResource MaterialDesignOutlinedButton}" Command="{Binding ClearQueueCommand}" HorizontalAlignment="Left" VerticalAlignment="Center" />
            </Grid>
        </Border>
    </Grid>
</UserControl>
