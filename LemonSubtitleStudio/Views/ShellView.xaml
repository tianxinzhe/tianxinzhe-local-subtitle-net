<Window x:Class="LemonSubtitleStudio.Views.ShellView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:prism="http://prismlibrary.com/"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Title="Lemon Subtitle Studio" Height="720" Width="1280">
    <DockPanel LastChildFill="True">
        <Grid x:Name="Sidebar" Width="240" DockPanel.Dock="Left" Background="#16213E">
            <Grid.RowDefinitions>
                <RowDefinition Height="80" />
                <RowDefinition Height="*" />
                <RowDefinition Height="80" />
            </Grid.RowDefinitions>
            <StackPanel Grid.Row="0" Orientation="Vertical" Margin="16,20,16,0">
                <TextBlock Text="Lemon" FontSize="18" FontWeight="Bold" Foreground="#FFA500" />
                <TextBlock Text="Subtitle Studio" FontSize="12" Foreground="#A0A0B0" />
            </StackPanel>
            <StackPanel Grid.Row="1" Margin="8,0,8,0">
                <Button Style="{StaticResource NavButtonStyle}"
                        Command="{Binding NavigateCommand}" 
                        CommandParameter="VideoToSubtitleView"
                        Margin="4,4,4,0">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Video" Width="16" Height="16" Margin="0,0,8,0" />
                        <TextBlock Text="视频转字幕" />
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource NavButtonStyle}"
                        Command="{Binding NavigateCommand}" 
                        CommandParameter="VideoToAudioView"
                        Margin="4,4,4,0">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Music" Width="16" Height="16" Margin="0,0,8,0" />
                        <TextBlock Text="视频转音频" />
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource NavButtonStyle}"
                        Command="{Binding NavigateCommand}" 
                        CommandParameter="AudioToSubtitleView"
                        Margin="4,4,4,0">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Microphone" Width="16" Height="16" Margin="0,0,8,0" />
                        <TextBlock Text="音频转字幕" />
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource NavButtonStyle}"
                        Command="{Binding NavigateCommand}" 
                        CommandParameter="SubtitleTranslationView"
                        Margin="4,4,4,0">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Translate" Width="16" Height="16" Margin="0,0,8,0" />
                        <TextBlock Text="字幕翻译" />
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource NavButtonStyle}"
                        Command="{Binding NavigateCommand}" 
                        CommandParameter="SubtitleEditorView"
                        Margin="4,4,4,0">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Edit" Width="16" Height="16" Margin="0,0,8,0" />
                        <TextBlock Text="字幕编辑" />
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource NavButtonStyle}"
                        Command="{Binding NavigateCommand}" 
                        CommandParameter="SettingsView"
                        Margin="4,4,4,0">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Settings" Width="16" Height="16" Margin="0,0,8,0" />
                        <TextBlock Text="软件设置" />
                    </StackPanel>
                </Button>
            </StackPanel>
            <StackPanel Grid.Row="2" Margin="16,0,16,16">
                <ComboBox x:Name="LanguageSelector" 
                          SelectedItem="{Binding SelectedLanguage}"
                          ItemsSource="{Binding Languages}"
                          Height="28"
                          Style="{StaticResource LanguageComboBoxStyle}" />
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,8,0,0">
                    <TextBlock Text="内存: " Foreground="#A0A0B0" FontSize="10" />
                    <TextBlock Text="{Binding MemoryUsage}" Foreground="#00C853" FontSize="10" />
                    <TextBlock Text=" CPU: " Foreground="#A0A0B0" FontSize="10" Margin="4,0,0,0" />
                    <TextBlock Text="{Binding CpuUsage}" Foreground="#FFA500" FontSize="10" />
                </StackPanel>
                <TextBlock Text="v1.0.0" FontSize="10" Foreground="#505060" HorizontalAlignment="Center" Margin="0,4,0,0" />
            </StackPanel>
        </Grid>
        <Border BorderThickness="1,0,0,0" BorderBrush="#2A2A4A">
            <ContentControl prism:RegionManager.RegionName="ContentRegion" />
        </Border>
    </DockPanel>
</Window>