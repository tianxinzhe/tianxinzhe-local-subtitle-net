
<UserControl x:Class="LemonSubtitleStudio.Views.ShellView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:prism="http://prismlibrary.com/"
             xmlns:viewModels="clr-namespace:LemonSubtitleStudio.ViewModels">
    <UserControl.DataContext>
        <viewModels:ShellViewModel />
    </UserControl.DataContext>
    <DockPanel LastChildFill="True">
        <Grid x:Name="Sidebar" Width="240" DockPanel.Dock="Left" Background="#16213E">
            <Grid.RowDefinitions>
                <RowDefinition Height="80" />
                <RowDefinition Height="*" />
                <RowDefinition Height="80" />
            </Grid.RowDefinitions>
            <StackPanel Grid.Row="0" Orientation="Vertical" Margin="16,20,16,0">
                <TextBlock Text="Lemon" FontSize="18" FontWeight="Bold" Foreground="#FFA500" />
                <TextBlock Text="Subtitle Studio" FontSize="12" Foreground="#A0A0B0" />
            </StackPanel>
            <StackPanel Grid.Row="1" Margin="8,0,8,0">
                <Button Content="🎬 视频转字幕" 
                        Style="{StaticResource NavButtonStyle}"
                        Command="{Binding NavigateCommand}" 
                        CommandParameter="VideoToSubtitleView"
                        Margin="4,4,4,0" />
                <Button Content="🎵 视频转音频" 
                        Style="{StaticResource NavButtonStyle}"
                        Command="{Binding NavigateCommand}" 
                        CommandParameter="VideoToAudioView"
                        Margin="4,4,4,0" />
                <Button Content="🎙️ 音频转字幕" 
                        Style="{StaticResource NavButtonStyle}"
                        Command="{Binding NavigateCommand}" 
                        CommandParameter="AudioToSubtitleView"
                        Margin="4,4,4,0" />
                <Button Content="🌐 字幕翻译" 
                        Style="{StaticResource NavButtonStyle}"
                        Command="{Binding NavigateCommand}" 
                        CommandParameter="SubtitleTranslationView"
                        Margin="4,4,4,0" />
                <Button Content="✏️ 字幕编辑" 
                        Style="{StaticResource NavButtonStyle}"
                        Command="{Binding NavigateCommand}" 
                        CommandParameter="SubtitleEditorView"
                        Margin="4,4,4,0" />
                <Button Content="⚙️ 软件设置" 
                        Style="{StaticResource NavButtonStyle}"
                        Command="{Binding NavigateCommand}" 
                        CommandParameter="SettingsView"
                        Margin="4,4,4,0" />
            </StackPanel>
            <StackPanel Grid.Row="2" Margin="16,0,16,16">
                <ComboBox x:Name="LanguageSelector" 
                          SelectedItem="{Binding SelectedLanguage}"
                          ItemsSource="{Binding Languages}"
                          Style="{StaticResource LanguageComboBoxStyle}" />
                <TextBlock Text="v1.0.0" FontSize="10" Foreground="#505060" HorizontalAlignment="Center" Margin="0,8,0,0" />
            </StackPanel>
        </Grid>
        <Border BorderThickness="1,0,0,0" BorderBrush="#2A2A4A">
            <ContentControl prism:RegionManager.RegionName="ContentRegion" />
        </Border>
    </DockPanel>
</UserControl>
