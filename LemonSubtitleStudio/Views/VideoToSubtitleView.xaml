<UserControl x:Class="LemonSubtitleStudio.Views.VideoToSubtitleView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Background="#111125">
    <Grid Background="#111125">
        <Grid.RowDefinitions>
            <RowDefinition Height="56" />
            <RowDefinition Height="48" />
            <RowDefinition Height="*" />
            <RowDefinition Height="36" />
        </Grid.RowDefinitions>

        <!-- Header Bar -->
        <Border Grid.Row="0" Background="#111125" BorderBrush="#534433" BorderThickness="0,0,0,1" Padding="16,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Video → Subtitle" FontSize="20" FontWeight="Bold" Foreground="#FFB95C" Margin="0,0,12,0" />
                    <Border Background="#294A77" CornerRadius="10" Padding="8,2" VerticalAlignment="Center">
                        <TextBlock Text="{Binding Tasks.Count, StringFormat={}{0} files}" Foreground="#FFB95C" FontSize="11" FontWeight="Bold" />
                    </Border>
                    <Border Background="#28283D" CornerRadius="12" Padding="12,4" Margin="12,0,0,0" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Memory" Width="14" Height="14" Foreground="#D9C3AC" Margin="0,0,4,0" VerticalAlignment="Center" />
                            <TextBlock Text="{Binding MemoryUsage}" Foreground="#E2E0FC" FontSize="11" Margin="0,0,12,0" VerticalAlignment="Center" />
                            <TextBlock Text="CPU:" Foreground="#D9C3AC" FontSize="11" Margin="0,0,4,0" VerticalAlignment="Center" />
                            <TextBlock Text="{Binding CpuUsage}" Foreground="#E2E0FC" FontSize="11" VerticalAlignment="Center" />
                        </StackPanel>
                    </Border>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="Export All" Style="{StaticResource MaterialDesignOutlinedButton}" Command="{Binding ExportAllCommand}" Margin="0,0,8,0" Padding="12,6" />
                    <Button Content="Start Processing" Style="{StaticResource MaterialDesignRaisedButton}" Command="{Binding StartProcessingCommand}" Padding="16,6" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Config Bar -->
        <Border Grid.Row="1" Background="#1A1A2E" BorderBrush="#534433" BorderThickness="0,0,0,1" Padding="16,0">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal" Margin="0,0,20,0">
                    <TextBlock Text="LANGUAGE" Style="{StaticResource LabelCapsStyle}" Margin="0,0,8,0" VerticalAlignment="Center" />
                    <ComboBox ItemsSource="{Binding Languages}" SelectedItem="{Binding SelectedLanguage}" Width="140" Style="{StaticResource MaterialDesignFloatingHintComboBox}" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,20,0">
                    <TextBlock Text="PRECISION" Style="{StaticResource LabelCapsStyle}" Margin="0,0,8,0" VerticalAlignment="Center" />
                    <ComboBox ItemsSource="{Binding ProcessingModes}" SelectedItem="{Binding SelectedProcessingMode}" Width="140" Style="{StaticResource MaterialDesignFloatingHintComboBox}" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,20,0">
                    <TextBlock Text="MODEL" Style="{StaticResource LabelCapsStyle}" Margin="0,0,8,0" VerticalAlignment="Center" />
                    <ComboBox ItemsSource="{Binding AvailableModels}" SelectedItem="{Binding SelectedModel}" Width="140" Style="{StaticResource MaterialDesignFloatingHintComboBox}" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <TextBlock Text="OUTPUT" Style="{StaticResource LabelCapsStyle}" Margin="0,0,8,0" VerticalAlignment="Center" />
                    <Border Background="#333348" CornerRadius="4" Padding="8,4" BorderBrush="#534433" BorderThickness="1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{Binding OutputDirectory}" Foreground="#D9C3AC" FontSize="11" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                            <Button Grid.Column="1" Background="Transparent" BorderThickness="0" Command="{Binding BrowseOutputDirectoryCommand}" Cursor="Hand" Padding="4,0">
                                <materialDesign:PackIcon Kind="FolderOpen" Width="14" Height="14" Foreground="#FFA500" />
                            </Button>
                        </Grid>
                    </Border>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Workspace Split -->
        <Grid Grid.Row="2" Margin="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="35*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="65*" />
            </Grid.ColumnDefinitions>

            <!-- Left Panel: File Queue -->
            <Border Grid.Column="0" Background="#1E1E32" BorderBrush="#534433" BorderThickness="1" CornerRadius="8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Margin="8" Padding="24,16" Background="#0C0C1F" BorderBrush="#534433" BorderThickness="1"
                            AllowDrop="True" Drop="DropHandler" Cursor="Hand" CornerRadius="8">
                        <Border.InputBindings>
                            <MouseBinding MouseAction="LeftClick" Command="{Binding SelectFileCommand}" />
                        </Border.InputBindings>
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                            <materialDesign:PackIcon Kind="CloudUpload" Width="32" Height="32" Foreground="#D9C3AC" Margin="0,0,0,8" HorizontalAlignment="Center" />
                            <TextBlock Text="Drop video files here" Foreground="#D9C3AC" FontSize="14" HorizontalAlignment="Center" />
                            <TextBlock Text="MP4, MKV, MOV, AVI (Max 2GB)" Foreground="#606070" FontSize="11" HorizontalAlignment="Center" Margin="0,4,0,0" />
                        </StackPanel>
                    </Border>

                    <ScrollViewer Grid.Row="1" Margin="4,0,4,4" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding Tasks}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="4,2" Padding="8,6" Background="#1E1E32" CornerRadius="0" BorderBrush="#2A2A3E" BorderThickness="0,0,0,1">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <Border Grid.Column="0" Width="36" Height="36" Background="#333348" CornerRadius="8" Margin="0,0,8,0">
                                                <materialDesign:PackIcon Kind="FileVideo" Width="18" Height="18" Foreground="#FFB95C" />
                                            </Border>
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding FileName}" Foreground="#E2E0FC" FontSize="12" FontWeight="Bold" TextTrimming="CharacterEllipsis" />
                                                <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                                    <TextBlock Text="{Binding FileSizeFormatted}" Foreground="#606070" FontSize="10" Margin="0,0,8,0" />
                                                    <TextBlock Text="•" Foreground="#606070" FontSize="10" Margin="0,0,8,0" />
                                                    <TextBlock Text="{Binding DurationFormatted}" Foreground="#606070" FontSize="10" />
                                                </StackPanel>
                                            </StackPanel>
                                            <TextBlock Grid.Column="2" Text="{Binding Progress, StringFormat={}{0}%}" Foreground="#FFB95C" FontSize="11" FontFamily="Consolas" VerticalAlignment="Center" />
                                            <ProgressBar Grid.Row="1" Grid.ColumnSpan="3" Value="{Binding Progress}" Maximum="100" Height="2" Margin="0,4,0,0"
                                                         Background="#333348" Foreground="#FFA500" BorderThickness="0" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>

            <GridSplitter Grid.Column="1" Width="4" Background="Transparent" />

            <!-- Right Panel -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="140" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="4" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!-- Video Preview -->
                    <Border Grid.Column="0" Background="#1E1E32" BorderBrush="#534433" BorderThickness="1" CornerRadius="8">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <MediaElement x:Name="VideoPlayer" Source="{Binding SelectedMediaPath}" Stretch="Uniform" LoadedBehavior="Manual" />
                            <Border Grid.Row="1" Background="#1A1A2E" Padding="12,8" BorderBrush="#534433" BorderThickness="0,1,0,0">
                                <StackPanel>
                                    <TextBlock Text="PROCESS TRACKING" Foreground="#D9C3AC" FontSize="10" FontWeight="Bold" Margin="0,0,0,6" />
                                    <Grid Margin="0,0,0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Orientation="Horizontal">
                                            <materialDesign:PackIcon Kind="CheckCircle" Width="14" Height="14" Foreground="{Binding AudioExtractionProgress, Converter={StaticResource ProgressToColorConverter}}" Margin="0,0,4,0" VerticalAlignment="Center" />
                                            <TextBlock Text="Audio Extraction" Foreground="{Binding AudioExtractionProgress, Converter={StaticResource ProgressToColorConverter}}" FontSize="11" VerticalAlignment="Center" />
                                        </StackPanel>
                                        <ProgressBar Grid.Column="1" Value="{Binding AudioExtractionProgress}" Maximum="100" Height="2" Margin="12,0" VerticalAlignment="Center" Background="#333348" Foreground="#4ADE80" BorderThickness="0" />
                                        <TextBlock Grid.Column="2" Text="{Binding AudioExtractionProgress, StringFormat={}{0}%}" Foreground="{Binding AudioExtractionProgress, Converter={StaticResource ProgressToColorConverter}}" FontSize="10" FontFamily="Consolas" VerticalAlignment="Center" />
                                    </Grid>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Orientation="Horizontal">
                                            <materialDesign:PackIcon Kind="Sync" Width="14" Height="14" Foreground="{Binding AsrProgress, Converter={StaticResource ProgressToColorConverter}}" Margin="0,0,4,0" VerticalAlignment="Center" />
                                            <TextBlock Text="ASR Recognition" Foreground="{Binding AsrProgress, Converter={StaticResource ProgressToColorConverter}}" FontSize="11" VerticalAlignment="Center" />
                                        </StackPanel>
                                        <ProgressBar Grid.Column="1" Value="{Binding AsrProgress}" Maximum="100" Height="2" Margin="12,0" VerticalAlignment="Center" Background="#333348" Foreground="#FFA500" BorderThickness="0" />
                                        <TextBlock Grid.Column="2" Text="{Binding AsrProgress, StringFormat={}{0}%}" Foreground="{Binding AsrProgress, Converter={StaticResource ProgressToColorConverter}}" FontSize="10" FontFamily="Consolas" VerticalAlignment="Center" />
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Border>

                    <GridSplitter Grid.Column="1" Width="4" Background="Transparent" />

                    <!-- Subtitle Script -->
                    <Border Grid.Column="2" Background="#1E1E32" BorderBrush="#534433" BorderThickness="1" CornerRadius="8">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Border Background="#28283D" Padding="12,6" BorderBrush="#534433" BorderThickness="0,0,0,1" CornerRadius="8,8,0,0">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="SUBTITLE SCRIPT" Foreground="#D9C3AC" FontSize="10" FontWeight="Bold" />
                                    <TextBlock Grid.Column="1" Text="{Binding Subtitles.Count, StringFormat='{}{0} entries'}" Foreground="#606070" FontSize="10" FontFamily="Consolas" VerticalAlignment="Center" />
                                </Grid>
                            </Border>
                            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                <ItemsControl ItemsSource="{Binding Subtitles}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Padding="8,6" BorderBrush="#534433" BorderThickness="0,0,0,1" Background="#111125">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="{Binding StartTimeFormatted}" Foreground="#FFB95C" FontSize="10" FontFamily="Consolas" Margin="0,0,8,0" VerticalAlignment="Center" />
                                                    <TextBlock Grid.Column="1" Text="{Binding OriginalText}" Foreground="#D9C3AC" FontSize="12" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                                                    <Button Grid.Column="2" Background="Transparent" BorderThickness="0" Padding="4,0" Command="{Binding DataContext.EditSubtitleCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}">
                                                        <materialDesign:PackIcon Kind="Edit" Width="14" Height="14" Foreground="#D9C3AC" />
                                                    </Button>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Grid>
                    </Border>
                </Grid>

                <GridSplitter Grid.Row="1" Height="4" Background="Transparent" />

                <!-- Event Log -->
                <Border Grid.Row="2" Background="#1E1E32" BorderBrush="#534433" BorderThickness="1" CornerRadius="8" Margin="0,6,0,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <Border Background="#28283D" Padding="12,4" BorderBrush="#534433" BorderThickness="0,0,0,1" CornerRadius="8,8,0,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="EVENT LOG" Foreground="#D9C3AC" FontSize="10" FontWeight="Bold" />
                                <TextBlock Grid.Column="1" Text="{Binding Logs.Count, StringFormat='{}{0} entries'}" Foreground="#606070" FontSize="10" />
                            </Grid>
                        </Border>
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="8">
                            <ItemsControl ItemsSource="{Binding Logs}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}" Foreground="#D9C3AC" FontSize="11" FontFamily="Consolas" Padding="2" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <!-- Bottom Bar -->
        <Border Grid.Row="3" Background="#1A1A2E" BorderBrush="#534433" BorderThickness="0,1,0,0" Padding="12,0">
            <Grid>
                <Button Content="Clear Queue" Style="{StaticResource MaterialDesignOutlinedButton}" Command="{Binding ClearQueueCommand}" HorizontalAlignment="Left" VerticalAlignment="Center" />
            </Grid>
        </Border>
    </Grid>
</UserControl>
