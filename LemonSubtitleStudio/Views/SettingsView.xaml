
<UserControl x:Class="LemonSubtitleStudio.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:viewModels="clr-namespace:LemonSubtitleStudio.ViewModels">
    <UserControl.DataContext>
        <viewModels:SettingsViewModel />
    </UserControl.DataContext>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60" />
            <RowDefinition Height="*" />
            <RowDefinition Height="60" />
        </Grid.RowDefinitions>
        <Grid Grid.Row="0" Background="#1A1A2E" Margin="8">
            <TextBlock Text="软件设置" FontSize="18" FontWeight="Bold" Foreground="White" Margin="16,0,0,0" />
        </Grid>
        <ScrollViewer Grid.Row="1" Margin="8">
            <StackPanel>
                <Border Background="#16213E" CornerRadius="8" Margin="0,0,0,8">
                    <StackPanel Margin="16">
                        <TextBlock Text="存储设置" FontSize="14" FontWeight="Bold" Foreground="#FFA500" Margin="0,0,0,12" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="80" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="模型存储路径:" Foreground="#A0A0B0" Margin="0,8,0,0" />
                            <TextBox Grid.Column="1" Text="{Binding ModelStoragePath}" Style="{StaticResource TextBoxStyle}" Margin="8,8,8,0" />
                            <Button Grid.Column="2" Content="浏览" Style="{StaticResource SecondaryButtonStyle}" Command="{Binding BrowseModelPathCommand}" Margin="0,8,0,0" />
                            <TextBlock Grid.Column="0" Text="默认输出目录:" Foreground="#A0A0B0" Margin="0,8,0,0" />
                            <TextBox Grid.Column="1" Text="{Binding DefaultOutputDirectory}" Style="{StaticResource TextBoxStyle}" Margin="8,8,8,0" />
                            <Button Grid.Column="2" Content="浏览" Style="{StaticResource SecondaryButtonStyle}" Command="{Binding BrowseOutputPathCommand}" Margin="0,8,0,0" />
                        </Grid>
                    </StackPanel>
                </Border>
                <Border Background="#16213E" CornerRadius="8" Margin="0,0,0,8">
                    <StackPanel Margin="16">
                        <TextBlock Text="模型设置" FontSize="14" FontWeight="Bold" Foreground="#FFA500" Margin="0,0,0,12" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="默认模型:" Foreground="#A0A0B0" Margin="0,8,0,0" />
                            <ComboBox Grid.Column="1" ItemsSource="{Binding Models}" SelectedItem="{Binding SelectedModel}" Style="{StaticResource ComboBoxStyle}" Margin="8,8,0,0" />
                            <TextBlock Grid.Column="0" Text="默认语言:" Foreground="#A0A0B0" Margin="0,8,0,0" />
                            <ComboBox Grid.Column="1" ItemsSource="{Binding Languages}" SelectedItem="{Binding SelectedLanguage}" Style="{StaticResource ComboBoxStyle}" Margin="8,8,0,0" />
                            <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="8,8,0,0">
                                <CheckBox IsChecked="{Binding UseGPU}" Content="启用 GPU 加速" Foreground="#A0A0B0" />
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>
                <Border Background="#16213E" CornerRadius="8">
                    <StackPanel Margin="16">
                        <TextBlock Text="关于" FontSize="14" FontWeight="Bold" Foreground="#FFA500" Margin="0,0,0,12" />
                        <TextBlock Text="Lemon Subtitle Studio" Foreground="White" />
                        <TextBlock Text="版本: 1.0.0" Foreground="#A0A0B0" FontSize="12" />
                        <TextBlock Text="基于 Whisper.net + ONNX Runtime" Foreground="#A0A0B0" FontSize="12" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
        <Grid Grid.Row="2" Background="#16213E" Margin="8">
            <Button Content="保存设置" Style="{StaticResource PrimaryButtonStyle}" Command="{Binding SaveCommand}" HorizontalAlignment="Right" />
        </Grid>
    </Grid>
</UserControl>
