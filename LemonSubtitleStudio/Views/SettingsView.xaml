<UserControl x:Class="LemonSubtitleStudio.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Background="#0F1419">
        <Grid Background="#0F1419">
        <Grid.RowDefinitions>
            <RowDefinition Height="72" />
            <RowDefinition Height="*" />
            <RowDefinition Height="60" />
        </Grid.RowDefinitions>
        <materialDesign:Card Grid.Row="0" Margin="8" Padding="16">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                <materialDesign:PackIcon Kind="Settings" Width="24" Height="24" Foreground="#FFA500" Margin="0,0,8,0" />
                <TextBlock Text="软件设置" FontSize="18" FontWeight="Bold" Foreground="White" />
            </StackPanel>
        </materialDesign:Card>
        <ScrollViewer Grid.Row="1" Margin="8" Background="#0F1419">
            <StackPanel>
                <materialDesign:Card Padding="16" Margin="0,0,0,8">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <materialDesign:PackIcon Kind="Harddisk" Width="16" Height="16" Foreground="#FFA500" Margin="0,0,4,0" />
                            <TextBlock Text="存储设置" FontSize="14" FontWeight="Bold" Foreground="#FFA500" />
                        </StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="80" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="模型存储路径:" Foreground="#A0A0B0" VerticalAlignment="Center" Margin="0,4,0,4" />
                            <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding ModelStoragePath}" Style="{StaticResource TextBoxStyle}" Margin="8,4,8,4" />
                            <Button Grid.Row="0" Grid.Column="2" Content="浏览" Style="{StaticResource SecondaryButtonStyle}" Command="{Binding BrowseModelPathCommand}" Margin="0,4,0,4" />
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="默认输出目录:" Foreground="#A0A0B0" VerticalAlignment="Center" Margin="0,4,0,4" />
                            <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding DefaultOutputDirectory}" Style="{StaticResource TextBoxStyle}" Margin="8,4,8,4" />
                            <Button Grid.Row="1" Grid.Column="2" Content="浏览" Style="{StaticResource SecondaryButtonStyle}" Command="{Binding BrowseOutputPathCommand}" Margin="0,4,0,4" />
                        </Grid>
                    </StackPanel>
                </materialDesign:Card>
                <materialDesign:Card Padding="16" Margin="0,0,0,8">
                    <StackPanel>
                        <Grid Margin="0,0,0,12">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                                <materialDesign:PackIcon Kind="Package" Width="16" Height="16" Foreground="#FFA500" Margin="0,0,4,0" />
                                <TextBlock Text="模型管理" FontSize="14" FontWeight="Bold" Foreground="#FFA500" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                <TextBlock Text="模型类别:" Foreground="#A0A0B0" Margin="0,0,8,0" VerticalAlignment="Center" />
                                <ComboBox ItemsSource="{Binding ModelCategories}" SelectedItem="{Binding ModelCategory}" 
                                          Width="140" Style="{StaticResource ComboBoxStyle}" />
                            </StackPanel>
                        </Grid>
                        <DataGrid ItemsSource="{Binding AvailableModels}" SelectedItem="{Binding SelectedModelInfo}"
                                  AutoGenerateColumns="False" Style="{StaticResource DataGridStyle}" Margin="0,0,0,12"
                                  MinHeight="120" MaxHeight="220">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="模型名称" Binding="{Binding Name}" Width="140" />
                                <DataGridTextColumn Header="状态" Binding="{Binding IsInstalled, Converter={StaticResource BoolToStatusConverter}}" Width="80" />
                                <DataGridTextColumn Header="大小" Binding="{Binding Size}" Width="100" />
                                <DataGridTemplateColumn Header="下载进度" Width="*">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Grid VerticalAlignment="Center" Margin="4,2">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <ProgressBar Grid.Column="0" Value="{Binding Progress, Mode=OneWay}" Maximum="100"
                                                             Height="14" Style="{StaticResource ProgressBarStyle}"
                                                             Minimum="0" />
                                                <TextBlock Grid.Column="1" Text="{Binding ProgressText}" 
                                                           Foreground="#A0A0B0" FontSize="11" Margin="6,0,0,0" 
                                                           VerticalAlignment="Center" MinWidth="50" TextAlignment="Right" />
                                            </Grid>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="默认" Binding="{Binding IsDefault, Converter={StaticResource BoolToCheckConverter}}" Width="60" />
                            </DataGrid.Columns>
                        </DataGrid>
                        <StackPanel Orientation="Horizontal">
                            <Button Content="下载" Style="{StaticResource PrimaryButtonStyle}"
                                    Command="{Binding DownloadModelCommand}"
                                    IsEnabled="{Binding SelectedModelInfo, Converter={StaticResource NullAndBoolConverter}, ConverterParameter=False}"
                                    Margin="0,0,8,0" />
                            <Button Content="删除" Style="{StaticResource SecondaryButtonStyle}"
                                    Command="{Binding DeleteModelCommand}"
                                    IsEnabled="{Binding SelectedModelInfo, Converter={StaticResource NullAndBoolConverter}, ConverterParameter=True}"
                                    Margin="0,0,8,0" />
                            <Button Content="设为默认" Style="{StaticResource SecondaryButtonStyle}"
                                    Command="{Binding SetDefaultModelCommand}"
                                    IsEnabled="{Binding SelectedModelInfo}" />
                        </StackPanel>
                    </StackPanel>
                </materialDesign:Card>
                <materialDesign:Card Padding="16" Margin="0,0,0,8">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <materialDesign:PackIcon Kind="Wrench" Width="16" Height="16" Foreground="#FFA500" Margin="0,0,4,0" />
                            <TextBlock Text="默认设置" FontSize="14" FontWeight="Bold" Foreground="#FFA500" />
                        </StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="默认模型:" Foreground="#A0A0B0" VerticalAlignment="Center" Margin="0,4,0,4" />
                            <ComboBox Grid.Row="0" Grid.Column="1" ItemsSource="{Binding Models}" SelectedItem="{Binding SelectedModel}" Style="{StaticResource ComboBoxStyle}" Margin="8,4,0,4" />
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="默认语言:" Foreground="#A0A0B0" VerticalAlignment="Center" Margin="0,4,0,4" />
                            <ComboBox Grid.Row="1" Grid.Column="1" ItemsSource="{Binding Languages}" SelectedItem="{Binding SelectedLanguage}" Style="{StaticResource ComboBoxStyle}" Margin="8,4,0,4" />
                            <CheckBox Grid.Row="2" Grid.Column="1" IsChecked="{Binding UseGPU}" Content="启用 GPU 加速" Foreground="#A0A0B0" Margin="8,4,0,4" />
                        </Grid>
                    </StackPanel>
                </materialDesign:Card>
                <materialDesign:Card Padding="16">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <materialDesign:PackIcon Kind="InformationOutline" Width="16" Height="16" Foreground="#FFA500" Margin="0,0,4,0" />
                            <TextBlock Text="关于" FontSize="14" FontWeight="Bold" Foreground="#FFA500" />
                        </StackPanel>
                        <TextBlock Text="Lemon Subtitle Studio" Foreground="White" />
                        <TextBlock Text="版本: 1.0.0" Foreground="#A0A0B0" FontSize="12" />
                        <TextBlock Text="基于 Whisper.net + ONNX Runtime" Foreground="#A0A0B0" FontSize="12" />
                    </StackPanel>
                </materialDesign:Card>
            </StackPanel>
        </ScrollViewer>
        <materialDesign:Card Grid.Row="2" Margin="8" Padding="8">
            <Button Content="保存设置" Style="{StaticResource PrimaryButtonStyle}" Command="{Binding SaveCommand}" HorizontalAlignment="Right" />
        </materialDesign:Card>
    </Grid>
</UserControl>