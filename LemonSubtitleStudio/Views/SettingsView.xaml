<UserControl x:Class="LemonSubtitleStudio.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Background="#111125">
    <ScrollViewer Background="#111125" VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24">

            <!-- Model Management -->
            <StackPanel Margin="0,0,0,28">
                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <materialDesign:PackIcon Kind="Chip" Width="20" Height="20" Foreground="#FFA500" Margin="0,0,8,0" VerticalAlignment="Center" />
                        <TextBlock Text="Model Management" FontSize="16" FontWeight="Bold" Foreground="#E2E0FC" VerticalAlignment="Center" />
                    </StackPanel>
                    <Border Grid.Column="1" Background="#1E1E32" CornerRadius="6" Padding="4">
                        <StackPanel Orientation="Horizontal">
                            <Button Content="Speech Recognition" Padding="10,4" FontSize="11" FontWeight="Bold"
                                    Background="#294A77" Foreground="#FFB95C" BorderThickness="0" Margin="2,0"
                                    Command="{Binding SwitchModelCategoryCommand}" CommandParameter="Speech" />
                            <Button Content="Translation" Padding="10,4" FontSize="11" FontWeight="Bold"
                                    Background="Transparent" Foreground="#D9C3AC" BorderThickness="0" Margin="2,0"
                                    Command="{Binding SwitchModelCategoryCommand}" CommandParameter="Translation" />
                        </StackPanel>
                    </Border>
                </Grid>

                <Border Background="#1E1E32" BorderBrush="#534433" BorderThickness="1" CornerRadius="8">
                    <Grid>
                        <!-- Header -->
                        <Border Background="#28283D" Padding="12,8" BorderBrush="#534433" BorderThickness="0,0,0,1" CornerRadius="8,8,0,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="160" />
                                    <ColumnDefinition Width="100" />
                                    <ColumnDefinition Width="80" />
                                    <ColumnDefinition Width="100" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Model Name" Foreground="#D9C3AC" FontSize="10" FontWeight="Bold" />
                                <TextBlock Grid.Column="1" Text="Category" Foreground="#D9C3AC" FontSize="10" FontWeight="Bold" />
                                <TextBlock Grid.Column="2" Text="Size" Foreground="#D9C3AC" FontSize="10" FontWeight="Bold" HorizontalAlignment="Center" />
                                <TextBlock Grid.Column="3" Text="Status" Foreground="#D9C3AC" FontSize="10" FontWeight="Bold" HorizontalAlignment="Center" />
                                <TextBlock Grid.Column="4" Text="Actions" Foreground="#D9C3AC" FontSize="10" FontWeight="Bold" HorizontalAlignment="Right" />
                            </Grid>
                        </Border>
                        <!-- Rows -->
                        <ItemsControl ItemsSource="{Binding AvailableModels}" Margin="4,0">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="#2A2A3E" BorderThickness="0,0,0,1" Padding="12,8">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="160" />
                                                <ColumnDefinition Width="100" />
                                                <ColumnDefinition Width="80" />
                                                <ColumnDefinition Width="100" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="{Binding Name}" Foreground="#E2E0FC" FontSize="12" FontWeight="Bold" VerticalAlignment="Center" />
                                            <TextBlock Grid.Column="1" Text="{Binding Category}" Foreground="#D9C3AC" FontSize="11" VerticalAlignment="Center" />
                                            <TextBlock Grid.Column="2" Text="{Binding Size}" Foreground="#D9C3AC" FontSize="11" FontFamily="Consolas" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                            <Border Grid.Column="3" Background="#0C0C1F" CornerRadius="10" Padding="8,2" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding StatusLabel}" Foreground="{Binding StatusColor}" FontSize="10" FontWeight="Bold" />
                                            </Border>
                                            <StackPanel Grid.Column="4" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                                <Button Content="Download" Padding="10,4" FontSize="11" FontWeight="Bold"
                                                        Background="#FFA500" Foreground="#462A00" BorderThickness="0" Margin="2,0"
                                                        Command="{Binding DataContext.DownloadModelCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}"
                                                        Visibility="{Binding IsInstalled, Converter={StaticResource InverseBoolToVisibilityConverter}}" />
                                                <Button Content="Downloaded" Padding="10,4" FontSize="11"
                                                        Background="#333348" Foreground="#606070" BorderThickness="0" Margin="2,0"
                                                        Visibility="{Binding IsInstalled, Converter={StaticResource BoolToVisibilityConverter}}" />
                                                <Button Content="Set Default" Padding="10,4" FontSize="11" FontWeight="Bold"
                                                        Background="#294A77" Foreground="#FFB95C" BorderThickness="0" Margin="2,0"
                                                        Command="{Binding DataContext.SetDefaultModelCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Grid>
                </Border>
            </StackPanel>

            <!-- Storage -->
            <StackPanel Margin="0,0,0,28">
                <Border BorderBrush="#534433" BorderThickness="0,0,0,1" Padding="0,0,0,8" Margin="0,0,0,16">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="FolderOpen" Width="20" Height="20" Foreground="#FFA500" Margin="0,0,8,0" VerticalAlignment="Center" />
                        <TextBlock Text="Storage &amp; File Paths" FontSize="16" FontWeight="Bold" Foreground="#E2E0FC" />
                    </StackPanel>
                </Border>
                <Border Background="#1E1E32" BorderBrush="#534433" BorderThickness="1" CornerRadius="8" Padding="20">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="24" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="MODEL INSTALLATION PATH" Foreground="#D9C3AC" FontSize="10" FontWeight="Bold" Margin="0,0,0,8" />
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBox Text="{Binding ModelStoragePath}" IsReadOnly="True" Style="{StaticResource MaterialDesignFloatingHintTextBox}" />
                                <Button Grid.Column="1" Content="Browse" Style="{StaticResource MaterialDesignOutlinedButton}" Command="{Binding BrowseModelPathCommand}" Margin="8,0,0,0" Padding="12,4" />
                            </Grid>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="DEFAULT OUTPUT DIRECTORY" Foreground="#D9C3AC" FontSize="10" FontWeight="Bold" Margin="0,0,0,8" />
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBox Text="{Binding DefaultOutputDirectory}" Style="{StaticResource MaterialDesignFloatingHintTextBox}" />
                                <Button Grid.Column="1" Content="Browse" Style="{StaticResource MaterialDesignOutlinedButton}" Command="{Binding BrowseOutputPathCommand}" Margin="8,0,0,0" Padding="12,4" />
                            </Grid>
                        </StackPanel>
                    </Grid>
                </Border>
            </StackPanel>

            <!-- Subtitle Naming Convention -->
            <StackPanel Margin="0,0,0,28">
                <Border BorderBrush="#534433" BorderThickness="0,0,0,1" Padding="0,0,0,8" Margin="0,0,0,16">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="FileDocument" Width="20" Height="20" Foreground="#FFA500" Margin="0,0,8,0" VerticalAlignment="Center" />
                        <TextBlock Text="Subtitle Naming Convention" FontSize="16" FontWeight="Bold" Foreground="#E2E0FC" />
                    </StackPanel>
                </Border>
                <Border Background="#1E1E32" BorderBrush="#534433" BorderThickness="1" CornerRadius="8" Padding="20">
                    <ItemsControl ItemsSource="{Binding NamingConventions}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Width="200" Height="100" Background="#1A1A2E" BorderBrush="#534433" BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,12,0" Cursor="Hand">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="*" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="{Binding Name}" FontSize="14" FontWeight="Bold" Foreground="#E2E0FC" />
                                            <Border Grid.Column="1" Width="16" Height="16" CornerRadius="8" BorderBrush="#534433" BorderThickness="2"
                                                    Background="{Binding IsSelected, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=RadioCheck}">
                                                <Border Width="8" Height="8" CornerRadius="4" Background="#FFA500" Visibility="{Binding IsSelected, Converter={StaticResource BoolToVisibilityConverter}}" />
                                            </Border>
                                        </Grid>
                                        <TextBlock Grid.Row="1" Text="{Binding Description}" Foreground="#D9C3AC" FontSize="11" Margin="0,4,0,0" />
                                        <Border Grid.Row="2" Background="#0C0C1F" CornerRadius="4" Padding="6,2">
                                            <TextBlock Text="{Binding Example}" Foreground="#606070" FontSize="10" FontFamily="Consolas" />
                                        </Border>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Border>
            </StackPanel>

            <!-- Footer -->
            <Border BorderBrush="#534433" BorderThickness="0,1,0,0" Padding="0,16,0,0" Margin="0,0,0,24">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="Settings are saved automatically." Foreground="#606070" FontSize="12" />
                        <TextBlock Text="View Advanced Config (JSON)" Foreground="#FFB95C" FontSize="11" Opacity="0.8" Cursor="Hand" Margin="0,4,0,0" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button Content="Restore Default Settings" Padding="12,6" FontSize="12"
                                Background="Transparent" Foreground="#FFB4AB" BorderBrush="#FFB4AB" BorderThickness="1"
                                Command="{Binding RestoreDefaultsCommand}" Margin="0,0,8,0" />
                        <Button Content="Save Settings" Style="{StaticResource MaterialDesignRaisedButton}" Command="{Binding SaveCommand}" />
                    </StackPanel>
                </Grid>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
