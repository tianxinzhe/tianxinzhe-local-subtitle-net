<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:converters="clr-namespace:LemonSubtitleStudio.Converters">

    <!-- Color Palette -->
    <Color x:Key="BgCanvas">#111125</Color>
    <Color x:Key="BgSurface">#111125</Color>
    <Color x:Key="BgSurfaceLow">#1A1A2E</Color>
    <Color x:Key="BgSurfaceContainer">#1E1E32</Color>
    <Color x:Key="BgSurfaceHigh">#28283D</Color>
    <Color x:Key="BgSurfaceHighest">#333348</Color>
    <Color x:Key="BgSurfaceLowest">#0C0C1F</Color>
    <Color x:Key="BgSurfaceVariant">#333348</Color>
    <Color x:Key="BgCard">#1E1E32</Color>
    <Color x:Key="BrandOrange">#FFA500</Color>
    <Color x:Key="BrandOrangeLight">#FFB95C</Color>
    <Color x:Key="BrandBlue">#294A77</Color>
    <Color x:Key="TextPrimary">#E2E0FC</Color>
    <Color x:Key="TextSecondary">#D9C3AC</Color>
    <Color x:Key="TextDisabled">#606070</Color>
    <Color x:Key="BorderDefault">#534433</Color>
    <Color x:Key="BorderLight">#6A5A4A</Color>
    <Color x:Key="Error">#FFB4AB</Color>
    <Color x:Key="Success">#4ADE80</Color>
    <Color x:Key="Processing">#448AFF</Color>

    <!-- Shell Navigation Button (plain WPF button, not MaterialDesign) -->
    <Style x:Key="NavButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="#D9C3AC" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="12,8" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="HorizontalContentAlignment" Value="Left" />
        <Setter Property="FontSize" Value="14" />
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="#333348" />
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
                <Setter Property="Background" Value="#3A3A5A" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- Label style for section headers -->
    <Style x:Key="LabelCapsStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="11" />
        <Setter Property="Foreground" Value="#D9C3AC" />
        <Setter Property="FontWeight" Value="Bold" />
    </Style>

    <!-- ScrollBar styling -->
    <Style TargetType="ScrollBar">
        <Setter Property="Background" Value="#1A1A2E" />
        <Setter Property="Foreground" Value="#534443" />
        <Setter Property="Width" Value="6" />
        <Setter Property="Height" Value="6" />
    </Style>

    <!-- Tab styling -->
    <Style TargetType="TabControl">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
    </Style>

    <Style TargetType="TabItem">
        <Setter Property="Background" Value="#1E1E32" />
        <Setter Property="Foreground" Value="#D9C3AC" />
        <Setter Property="Padding" Value="12,8" />
        <Setter Property="BorderBrush" Value="#534433" />
        <Setter Property="BorderThickness" Value="0" />
        <Style.Triggers>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="#0C0C1F" />
                <Setter Property="Foreground" Value="#FFB95C" />
            </Trigger>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Foreground" Value="#E2E0FC" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- Converters -->
    <converters:BoolToStatusConverter x:Key="BoolToStatusConverter" />
    <converters:BoolToCheckConverter x:Key="BoolToCheckConverter" />
    <converters:NullAndBoolConverter x:Key="NullAndBoolConverter" />
    <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
    <converters:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibilityConverter" />
    <converters:InverseBoolConverter x:Key="InverseBoolConverter" />
    <converters:EqualityConverter x:Key="EqualityConverter" />
</ResourceDictionary>
